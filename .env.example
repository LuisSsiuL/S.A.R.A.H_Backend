# Copy this file to .env and fill in your values.

# PostgreSQL connection string (from Supabase: Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase project URL and keys (Settings → API Keys)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-key-here

# DeepSeek API (used as OpenAI-compatible endpoint for SQL generation)
OPENAI_API_KEY=your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Standard OpenAI API (for text-embedding-3-small; optional — disables cache if omitted)
STANDARD_OPENAI_API_KEY=your-openai-api-key

# Comma-separated list of allowed frontend origins for CORS
# Add your production frontend URL here when deploying
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
